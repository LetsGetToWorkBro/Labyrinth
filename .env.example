# IMPORTANT: Variables prefixed with VITE_ are compiled into the JS bundle at build time
# and are visible to anyone who views your app's source code in a browser.
# NEVER put secrets, API keys, or tokens in VITE_ variables.
# VITE_ variables should only contain public config (public URLs, feature flags, public IDs).
#
# Secrets that must stay server-side:
# - PASS_API_SECRET → set in Railway environment variables only (not here)
# - Any private API keys → use server-side environment variables only

# Public Sentry DSN — safe for client bundle (Sentry DSNs are designed to be public).
# Rate limiting is configured in the Sentry dashboard, not here.
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
